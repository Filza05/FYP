--- !u!114 &1955896820
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1955896816}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 490231dd090d15643ace2e0719884f7e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  chapters:
  - chapterID: Chapter 1
    title: How the Main Menu Buttons Work
    background: {fileID: 21300000, guid: 2a25012acc8cdde4da4eaaf15aa45d6f, type: 3}
    description: "-Host a Lobby: Join a 3d world and invite others to join via join
      code, roam around and socialize!\n\n-Join Random Lobby: Click here to be sent
      to a random game room with other players. You never know who you\u2019ll meet!\n\n-Join
      with Join Code: If someone gives you a special code, use this button to join
      their private game room.\n\n-Browse Available Lobbies: Look through a list
      of open game rooms and pick one that you want to join."
    defaultState: 3
    titleKey: Chapter1Title
    descriptionKey: Chapter1Description
    onContinue:
      m_PersistentCalls:
        m_Calls: []
    onPlay:
      m_PersistentCalls:
        m_Calls: []
    onReplay:
      m_PersistentCalls:
        m_Calls: []
  - chapterID: Chapter 2
    title: Interact with Information Desk
    background: {fileID: 21300000, guid: 3404a48688f695440911efb6eab94d40, type: 3}
    description: "-The Information Desk is your go-to spot for sharing important
      details with the community! Whether you have info about upcoming events, hackathons,
      game nights, or anything else, this is where you can submit it.\n\n-Just Press
      TAB near the desk and fill out the form with all the details\u2014like event
      name, time, location, and any extra information you think others would need.
      Make sure to include any important links or contact info!\n\n-You can share
      anything that might be helpful for others\u2014events, competitions, meetups,
      or special announcements! Whether it\u2019s a local hackathon, an online tournament,
      or even a fun hangout, this is the place to let others know.\n"
    defaultState: 3
    titleKey: Chapter2Title
    descriptionKey: Chapter2Description
    onContinue:
      m_PersistentCalls:
        m_Calls: []
    onPlay:
      m_PersistentCalls:
        m_Calls: []
    onReplay:
      m_PersistentCalls:
        m_Calls: []
  - chapterID: Chapter 3
    title: View Submitted Information from an NPC
    background: {fileID: 21300000, guid: 505a152a5e7165f4c919c0e13431409b, type: 3}
    description: "Once you submit your info, an NPC (Non-Player Character) will be
      spawned in the game world, waving to grab attention! Other players will have
      to explore and find the NPC to view the details you submitted. It\u2019s like
      a mini scavenger hunt! Keep an eye out, and make sure to check the desk for
      any updates or new info popping up. Happy hunting! "
    defaultState: 0
    titleKey: Chapter3Title
    descriptionKey: Chapter3Description
    onContinue:
      m_PersistentCalls:
        m_Calls: []
    onPlay:
      m_PersistentCalls:
        m_Calls: []
    onReplay:
      m_PersistentCalls:
        m_Calls: []
  - chapterID: Chapter 4
    title: Pause Menu
    background: {fileID: 21300000, guid: e5a69b6a543ef88409b6aee5c44d268f, type: 3}
    description: '-Press ESCAPE key to bring up the pause menu.


      -Here you
      can Mute other players, lower their speaking volume, send text chats, speak
      incoming messages using TEXT TO SPEECH (TTS) and leave/delete the Lobby.


      -If
      you hosted the Lobby, it will be deleted and all participants will be removed.


      -If
      you did not host a lobby, yuou can simply leave it and the world will not be
      affected.'
    defaultState: 0
    titleKey: Chapter4Title
    descriptionKey: Chapter4Description
    onContinue:
      m_PersistentCalls:
        m_Calls: []
    onPlay:
      m_PersistentCalls:
        m_Calls: []
    onReplay:
      m_PersistentCalls:
        m_Calls: []
  - chapterID: Chapter 5
    title: Information Board
    background: {fileID: 21300000, guid: eab64b657dffe68458d6100ae814e66d, type: 3}
    description: '-Press E key to create an information board.


      -Use scroll
      wheel to rotate it and move mouse for placement.


      -When done, press
      mouse key to place it and enter details like your ongoing projects demanding
      collaboration etc.


      other players can view this information.'
    defaultState: 0
    titleKey: Chapter4Title
    descriptionKey: Chapter4Description
    onContinue:
      m_PersistentCalls:
        m_Calls: []
    onPlay:
      m_PersistentCalls:
        m_Calls: []
    onReplay:
      m_PersistentCalls:
        m_Calls: []
